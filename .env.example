# ── LLM ───────────────────────────────────────────────────────────────────────
# Switch provider by changing these two lines — no code changes needed.
#
# OpenAI:
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-...
#
# Anthropic (comment out OpenAI lines above, uncomment below):
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-3-5-haiku-20241022
# ANTHROPIC_API_KEY=sk-ant-...

# ── Qdrant ─────────────────────────────────────────────────────────────────────
# Local (docker-compose): leave as default
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Qdrant Cloud (for Railway deployment):
# QDRANT_URL=https://your-cluster.qdrant.io
# QDRANT_API_KEY=your-qdrant-cloud-api-key

QDRANT_COLLECTION=gdpr_docs

# ── Embeddings ─────────────────────────────────────────────────────────────────
# "huggingface" = free, runs locally, no API key needed (default)
#   model: all-MiniLM-L6-v2 (384 dims) — good quality, fast
# "openai" = better quality, costs ~$0.001 for the full corpus
#   model: text-embedding-3-small (1536 dims)
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Uncomment to switch to OpenAI embeddings (better retrieval quality):
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# Note: re-run python ingest.py after switching — different vector dimensions

# ── RAG ────────────────────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=5
