# ── LLM ───────────────────────────────────────────────────────────────────────
# Switch provider by changing these two lines — no code changes needed.
#
# OpenAI:
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-...
#
# Anthropic (comment out OpenAI lines above, uncomment below):
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-3-5-haiku-20241022
# ANTHROPIC_API_KEY=sk-ant-...

# ── Qdrant ─────────────────────────────────────────────────────────────────────
# Local (docker-compose): leave as default
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Qdrant Cloud (for Railway deployment):
# QDRANT_URL=https://your-cluster.qdrant.io
# QDRANT_API_KEY=your-qdrant-cloud-api-key

QDRANT_COLLECTION=gdpr_docs

# ── Embeddings ─────────────────────────────────────────────────────────────────
# Always uses OpenAI embeddings — text-embedding-3-small is cheap ($0.02/1M tokens)
# Requires OPENAI_API_KEY above even when using Anthropic as the LLM.
EMBEDDING_MODEL=text-embedding-3-small

# ── RAG ────────────────────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=5
